# Maintainer: lightsaway <lightsaway@users.noreply.github.com>
pkgname=eyes-break-reminder
pkgver=0.1.0
pkgrel=1
pkgdesc="Lightweight break reminder app — follow the 20-20-20 rule"
arch=('x86_64' 'aarch64')
url="https://github.com/lightsaway/eyes"
license=('MIT')
depends=('gtk3' 'libappindicator-gtk3' 'libnotify' 'libcanberra' 'libxss')
makedepends=('zig')
source=("$pkgname-$pkgver.tar.gz::https://github.com/lightsaway/eyes/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "eyes-$pkgver"
  zig build -Doptimize=ReleaseFast
}

package() {
  cd "eyes-$pkgver"
  install -Dm755 zig-out/bin/eyes "$pkgdir/usr/bin/eyes"
  install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/eyes.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Eyes
Comment=Break reminder — follow the 20-20-20 rule
Exec=eyes
Icon=view-reveal-symbolic
Categories=Utility;
EOF
}
